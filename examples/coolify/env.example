# Image tag used for all Jitsi services.
JITSI_IMAGE_VERSION=stable

# Public HTTPS URL served by Coolify.
PUBLIC_URL=https://jitsi.deine-domain.de

# Set your server timezone.
TZ=Europe/Berlin

# REQUIRED: generate long random secrets.
JICOFO_AUTH_PASSWORD=replace-with-long-random-string
JVB_AUTH_PASSWORD=replace-with-long-random-string

# REQUIRED: public IP(s) announced by JVB. Comma separated for multiple IPs.
# Wrong value = ICE keepalive failures after ~15 s → screen sharing drops
JVB_ADVERTISE_IPS=203.0.113.10

# Media transport settings.
JVB_PORT=10000
JVB_STUN_SERVERS=meet-jit-si-turnrelay.jitsi.net:443

# Coolify proxy mode (recommended): keep HTTPS disabled in the container.
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0

# Temporary diagnostics while investigating media drops.
PROSODY_LOG_LEVEL=debug
JICOFO_LOG_LEVEL=FINE
JVB_LOG_LEVEL=FINE
JICOFO_LOG_FILE=/config/jicofo.log
JVB_LOG_FILE=/config/jvb.log
# Optional extra java.util.logging lines, newline-separated.
JICOFO_EXTRA_LOGGERS=
JVB_EXTRA_LOGGERS=

# Optional explicit XMPP defaults.
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
