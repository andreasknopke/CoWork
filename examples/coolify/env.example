# Image tag used for all Jitsi services.
JITSI_IMAGE_VERSION=stable

# Public HTTPS URL served by Coolify.
PUBLIC_URL=https://jitsi.deine-domain.de

# Set your server timezone.
TZ=Europe/Berlin

# REQUIRED: generate long random secrets.
JICOFO_AUTH_PASSWORD=replace-with-long-random-string
JVB_AUTH_PASSWORD=replace-with-long-random-string

# REQUIRED: public IP(s) announced by JVB. Comma separated for multiple IPs.
# Wrong value = ICE keepalive failures after ~15 s → screen sharing drops
JVB_ADVERTISE_IPS=203.0.113.10

# Media transport settings.
JVB_PORT=10000
JVB_STUN_SERVERS=meet-jit-si-turnrelay.jitsi.net:443

# Bundled coturn relay on the same host.
# Reuse the same public hostname if you want to avoid an extra DNS entry.
STUN_HOST=jitsi.deine-domain.de
STUN_PORT=3478
TURN_HOST=jitsi.deine-domain.de
TURN_EXTERNAL_IP=203.0.113.10
TURN_PORT=3478
TURN_MIN_PORT=20000
TURN_MAX_PORT=20050
TURN_CREDENTIALS=replace-with-another-long-random-string
# Leave TURNS_HOST empty in this minimal same-host setup.

# Optional for an external TURN/TURNS service instead of the bundled container.
# TURNS_HOST=turn.example.com
# TURNS_PORT=5349
# TURN_TRANSPORT=udp,tcp
# TURN_TTL=86400
# TURN_USERNAME=jitsi
# TURN_PASSWORD=replace-with-turn-password

# Coolify proxy mode (recommended): keep HTTPS disabled in the container.
DISABLE_HTTPS=1
ENABLE_HTTP_REDIRECT=0

# Exact ~77s idle disconnects are usually the browser-to-proxy XMPP websocket path,
# not a Jitsi demo timer. Disable XMPP websocket by default in Coolify so the
# client is forced onto BOSH for signaling.
ENABLE_XMPP_WEBSOCKET=0

# Keep BOSH preferred even if you later re-enable websocket for comparison.
# Set websocket to 1 only after you have confirmed stable upgraded connections
# in your outer proxy.
PREFER_BOSH=1

# Local-only workaround for deterministic ~70s room drops.
# This performs a silent same-room leave/join shortly before the failure window.
ENABLE_LOCAL_RECOVERY_WORKAROUND=1
LOCAL_RECOVERY_REJOIN_MILLISECONDS=55000

# Backup path if the ICE connection interrupts before the timer fires.
LOCAL_RECOVERY_INTERRUPT_GRACE_MILLISECONDS=2500

# Reload only if the silent rejoin stalls or fails.
LOCAL_RECOVERY_REJOIN_TIMEOUT_MILLISECONDS=15000
LOCAL_RECOVERY_MIN_INTERVAL_MILLISECONDS=10000
LOCAL_RECOVERY_RELOAD_FALLBACK=1

# Harden WebSocket handling behind reverse proxies to avoid ~60-70s disconnects.
XMPP_WEBSOCKET_PROXY_READ_TIMEOUT=3600s
XMPP_WEBSOCKET_PROXY_SEND_TIMEOUT=3600s
COLIBRI_WEBSOCKET_PROXY_READ_TIMEOUT=3600s
COLIBRI_WEBSOCKET_PROXY_SEND_TIMEOUT=3600s

# Allow Prosody more time to resume XMPP sessions after a transient websocket drop.
PROSODY_SMACKS_HIBERNATION_TIME=300

# Temporary diagnostics while investigating media drops.
PROSODY_LOG_LEVEL=debug
JICOFO_LOG_LEVEL=FINE
JVB_LOG_LEVEL=FINE
JICOFO_LOG_FILE=/config/jicofo.log
JVB_LOG_FILE=/config/jvb.log
# Optional extra java.util.logging lines, newline-separated.
JICOFO_EXTRA_LOGGERS=
JVB_EXTRA_LOGGERS=

# Optional explicit XMPP defaults.
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
